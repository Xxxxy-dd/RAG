# Example .env for RAG project
# Copy this to .env and fill values locally or provide via CI/Secrets

# Chroma storage path
CHROMA_DB_DIR=./chroma_db

# Embedding / LLM provider
EMBEDDING_PROVIDER=local
LLM_PROVIDER=local

# FastAPI
API_HOST=127.0.0.1
API_PORT=8000

# Embeddings provider (set an API key if using a remote provider)
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-v1

# LLM provider settings
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT=60

# Rerank model (optional)
RERANK_MODEL=
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_TIMEOUT=60

# MySQL (for local dev you can run via docker-compose)
# Either set DATABASE_URL or the MYSQL_* variables below
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/rag?charset=utf8mb4
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=rag
MYSQL_CHARSET=utf8mb4

# Redis (defaults used by project)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Notes:
# - Do NOT commit .env with real secrets. Use CI secrets or your OS environment.
# - In CI, set DATABASE_URL, EMBEDDINGS_API_KEY, LLM_API_KEY, and other secrets
#   via repository secrets rather than committing them.
